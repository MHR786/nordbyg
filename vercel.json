{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm i -g pnpm@10.33.2 && pnpm install --filter @workspace/nordbyg-expo... --frozen-lockfile=false",
  "buildCommand": "PORT=3000 BASE_PATH=/ pnpm --filter @workspace/nordbyg-expo build",
  "outputDirectory": "artifacts/nordbyg-expo/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
